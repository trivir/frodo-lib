            "text": "{\"name\":\"phh-delegated-user-disable-form\",\"type\":\"request\",\"description\":\"Form for disabling users with delegation authority\",\"categories\":{\"applicationType\":null,\"objectType\":null,\"operation\":\"create\"},\"form\":{\"fields\":[{\"id\":\"ef298ed6-7f50-456a-9473-934eee627b36\",\"fields\":[{\"id\":\"988aad8c-9ef4-4a83-8717-960931b89695\",\"model\":\"actingPrincipalId\",\"type\":\"string\",\"label\":\"Acting on behalf of\",\"description\":\"Enter the username of individual you are performing the operation for\",\"validation\":{\"required\":true},\"layout\":{\"columns\":12,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}}]},{\"id\":\"8587be1b-8a68-4a9a-bbfb-26dc47911897\",\"fields\":[{\"id\":\"4b64f437-f304-434a-9cb7-20227549b778\",\"model\":\"availableDirectReports\",\"type\":\"string\",\"label\":\"Your direct reports\",\"description\":\"These are those you can act on behalf of.\",\"validation\":{\"required\":true},\"layout\":{\"columns\":12,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}}]},{\"id\":\"b24286b5-07ba-420f-9238-667035368e93\",\"fields\":[{\"id\":\"13c44f83-9f4e-4da1-83ce-60137f25bcd9\",\"model\":\"targetUserId\",\"type\":\"string\",\"label\":\"Target User to Disable\",\"description\":\"User to be disabled\",\"validation\":{\"required\":true},\"layout\":{\"columns\":12,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}}]},{\"id\":\"915f0cd0-27e1-4d3d-bf55-bf3c1a7697e0\",\"fields\":[{\"id\":\"0ccdeb3c-5df7-45df-95ef-5ed10be592c6\",\"model\":\"justification\",\"type\":\"textarea\",\"label\":\"Justification\",\"description\":\"Why is this user being disabled?\",\"validation\":{\"required\":true},\"layout\":{\"columns\":12,\"offset\":0},\"readOnly\":false,\"customSlot\":false,\"onChangeEvent\":{}}]},{\"id\":\"7ab82555-de43-4840-adbb-f2ea959b6d9e\",\"fields\":[{\"id\":\"f5b98b5c-1f2b-4609-bcb1-2eb5d6d02953\",\"model\":\"confirmationMessage\",\"ty