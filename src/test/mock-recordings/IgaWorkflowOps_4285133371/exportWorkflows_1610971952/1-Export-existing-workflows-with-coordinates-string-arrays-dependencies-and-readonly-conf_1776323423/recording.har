he grant\"}},\"blob\":{\"isRequired\":false,\"isInternal\":true}}},\"properties\":{\"justification\":{\"type\":\"text\"},\"externalRequestId\":{\"type\":\"text\"},\"requestIdPrefix\":{\"type\":\"text\"},\"isDraft\":{\"type\":\"boolean\"},\"priority\":{\"type\":\"text\"},\"expiryDate\":{\"type\":\"text\"},\"context\":{\"type\":\"object\"},\"workflowId\":{\"type\":\"text\"},\"startDate\":{\"type\":\"text\"},\"endDate\":{\"type\":\"text\"},\"blob\":{\"type\":\"object\"}}}],\"entitlement\":[{\"_meta\":{\"type\":\"system\",\"display\":\"Entitlement Modification\",\"properties\":{\"entitlementId\":{\"isRequired\":true,\"isInternal\":true,\"isMultiValue\":false,\"lookup\":{\"path\":\"/iga/index/catalog\",\"query\":\"assignment/id/keyword eq \\\"${entitlementId}\\\" and item/type/keyword eq \\\"entitlementGrant\\\"\"},\"display\":{\"name\":\"Entitlement\",\"isVisible\":true,\"order\":1,\"description\":\"The ID of the entitlement being modified (assignment id)\"}},\"object\":{\"isRequired\":false,\"isInternal\":true,\"display\":{\"name\":\"Entitlement Contents\",\"isVisible\":true,\"description\":\"The contents of the entitlement object (technical data)\"}},\"glossary\":{\"isRequired\":false,\"isInternal\":true,\"display\":{\"name\":\"Glossary\",\"isVisible\":true,\"description\":\"The contents of the entitlement's glossary (business data)\"}}}},\"properties\":{\"entitlementId\":{\"type\":\"text\"},\"object\":{\"type\":\"object\"},\"glossary\":{\"type\":\"object\"}}}]},\"workflow\":{\"id\":\"ModifyEntitlement\",\"type\":\"bpmn\"},\"validation\":{\"source\":\"var validation = {\\\"errors\\\" : [], \\\"comments\\\" : []};if(object.requester.id.startsWith(\\\"managed/user/\\\")){var userId = object.requester.id.split('/');try{var entitlement = openidm.action(\\\"iga/governance/entitlement/\\\" + request.entitlement.entitlementId, 'GET', {}, {\\\"endUserId\\\": userId[2]});if(!entitlement.permissions.modifyEntitlement){validation.errors.push(\\\"User does not have permission to 