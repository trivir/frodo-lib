eId,\\n                \\\"userId\\\": request.common.userId,\\n                \\\"endDate\\\": request.common.endDate,\\n                \\\"justification\\\": \\\"Request submitted automatically to remove access granted by request: \\\" + requestId\\n            }\\n        };\\n        var queryParam = {\\n            '_action': \\\"publish\\\"\\n        }\\n        openidm.action('iga/governance/requests/roleRemove', 'POST', newRequestPayload, queryParam)\\n     }catch(e){\\n         logger.info('Create Removal Request creation failed')\\n     }\\n    }\"}}],\"staticNodes\":{\"startNode\":{\"id\":\"startNode\",\"x\":70,\"y\":140,\"connections\":{\"start\":\"scriptTask-d76490953517\"}},\"endNode\":{\"id\":\"endNode\",\"x\":2889,\"y\":467,\"connections\":null},\"uiConfig\":{\"scriptTask-3eab1948f1ec\":{\"x\":1428,\"y\":56.015625},\"exclusiveGateway-48e748c42994\":{\"x\":1694,\"y\":23.015625},\"scriptTask-0b56191887de\":{\"x\":1939,\"y\":149.015625},\"scriptTask-0359a9d77ee2\":{\"x\":1941,\"y\":65.015625},\"scriptTask-aec6c36b3a45\":{\"x\":1399,\"y\":325.015625},\"scriptTask-d76490953517\":{\"x\":161,\"y\":142.015625},\"exclusiveGateway-8cd9decab2e4\":{\"x\":453,\"y\":120.015625},\"scriptTask-8506123e6208\":{\"x\":721,\"y\":41.015625},\"inclusiveGateway-57e9b96eb570\":{\"x\":939,\"y\":39.015625},\"approvalTask-c7867dd2593a\":{\"x\":727,\"y\":144.015625,\"actors\":[{\"id\":{\"isExpression\":true,\"value\":\"(function() {\\n  var systemSettings = openidm.action(\\\"iga/commons/config/iga_access_request\\\", \\\"GET\\\", {}, {});\\n  var approver = null;\\n  if (requestIndex.roleOwner && requestIndex.roleOwner[0]) {\\n    approver = \\\"managed/user/\\\" + requestIndex.roleOwner[0].id;\\n  } else if (systemSettings && systemSettings.defaultApprover) {\\n    approver = systemSettings.defaultApprover;\\n  }\\n  return approver;\\n})()\"},\"type\":\"roleOwner\"}],\"events\":{\"expirationDate\":7,\"expirationTimeSpan\":\"day(s)\",\"reminderDate\":3,\"reminderTimeSpan\":\