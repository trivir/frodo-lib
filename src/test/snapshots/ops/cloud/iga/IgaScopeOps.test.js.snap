    },
    "dd0466f4-c4d9-4eba-8d10-e2f131eab905": {
      "_rev": 1,
      "description": "Allows employees (frIndexedInteger1 eq 0) to view other employee objects",
      "id": "dd0466f4-c4d9-4eba-8d10-e2f131eab905",
      "metadata": {
        "createdDate": "2026-05-21T19:44:52.982757902Z",
        "modifiedDate": "2026-05-21T19:44:52.982778308Z",
      },
      "name": "phh-delegate-visibility",
      "sourceCondition": {
        "user": {
          "filter": {
            "and": [
              {
                "equals": {
                  "left": "user.frIndexedInteger1",
                  "right": {
                    "literal": 0,
                  },
                },
              },
            ],
          },
          "version": "v2",
        },
      },
      "status": "inactive",
      "targetCondition": {
        "user": {
          "filter": {
            "and": [
              {
                "equals": {
                  "left": "user.frIndexedInteger1",
                  "right": {
                    "literal": 0,
                  },
                },
              },
            ],
          },
          "version": "v2",
        },
      },
    },
  },
}
