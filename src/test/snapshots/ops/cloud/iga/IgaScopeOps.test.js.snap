            ],
          },
          "version": "v2",
        },
        "user": {
          "filter": {
            "or": [
              {
                "starts_with": {
                  "prefix": {
                    "literal": "1",
                  },
                  "value": "user._id",
                },
              },
            ],
          },
          "version": "v2",
        },
      },
    },
