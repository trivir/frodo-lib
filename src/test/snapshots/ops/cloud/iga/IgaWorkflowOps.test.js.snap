          {
            "displayName": "Context Check",
            "name": "scriptTask-365b50ab00a7",
            "scriptTask": {
              "language": "javascript",
              "nextStep": [
                {
                  "condition": "true",
                  "outcome": "done",
                  "step": "exclusiveGateway-c82a357d8c38",
