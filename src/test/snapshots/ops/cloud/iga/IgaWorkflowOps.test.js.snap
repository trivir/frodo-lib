                  "notification": "requestReminder",
                },
              },
              "nextStep": [
                {
                  "condition": null,
                  "outcome": "APPROVE",
                  "step": "scriptTask-0359a9d77ee2",
                },
                {
                  "condition": null,
                  "outcome": "REJECT",
                  "step": "scriptTask-aec6c36b3a45",
