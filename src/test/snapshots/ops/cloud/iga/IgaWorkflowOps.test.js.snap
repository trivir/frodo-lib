                },
                {
                  "condition": [
                    "enableWait == false",
                  ],
                  "outcome": "noEndDate",
                  "step": "scriptTask-0359a9d77ee2",
                },
              ],
              "script": [
                "logger.info("This is inclusive gateway");",
              ],
            },
            "type": "scriptTask",
          },
          {
            "displayName": "Wait Task",
            "name": "waitTask-e65fcbd06a6d",
            "type": "waitTask",
            "waitTask": {
              "nextStep": [
                {
                  "condition": [
                    "true",
                  ],
                  "outcome": "COMPLETE",
                  "step": "scriptTask-0359a9d77ee2",
                },
              ],
              "resumeDate": {
                "isExpression": true,
                "value": [
                  "requestIndex.request.common.endDate",
                ],
              },
            },
          },
        ],
        "type": "provisioning",
      },
    },
