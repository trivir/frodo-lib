        },
        "status": "published",
        "steps": [
          {
            "approvalMode": "any",
            "approvalTask": {
              "actors": [
                {
                  "id": {
                    "isExpression": true,
                    "value": [
                      ""managed/user/" + requestIndex.applicationOwner[0].id",
                    ],
                  },
                  "permissions": {
                    "approve": true,
                    "comment": true,
                    "modify": true,
                    "reassign": true,
                    "reject": true,
                  },
                },
              ],
              "approvalMode": "any",
              "events": {
                "assignment": {
                  "notification": "requestAssigned",
                },
                "expiration": {
                  "action": "reject",
                  "actors": [],
                  "date": {
                    "isExpression": true,
                    "value": [
                      "(new Date(new Date().getTime()+(7*24*60*60*1000))).toISOString()",
                    ],
                  },
