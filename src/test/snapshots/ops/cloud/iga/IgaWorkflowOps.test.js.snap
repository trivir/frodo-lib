            "name": "exclusiveGateway-67a954f33919",
            "scriptTask": {
              "language": "javascript",
              "nextStep": [
                {
                  "condition": "skipApproval == true",
                  "outcome": "AutoApproval",
                  "step": "scriptTask-e21178ab80f7",
